# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Apify ---
APIFY_TOKEN=
APIFY_FOLLOWING_ACTOR=scraping_solutions~instagram-scraper-followers-following-no-cookies
APIFY_PROFILE_ACTOR=apify~instagram-profile-scraper
APIFY_POSTS_ACTOR=apify~instagram-post-scraper

# --- Claude ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# --- Optional: ScrapingBee for link-in-bio ---
SCRAPINGBEE_API_KEY=

# --- Serper.dev (Google Search API: find YouTube channels for email lookup) ---
SERPER_API_KEY=

# --- Gmail SMTP (outreach sending) ---
# 16-char app password from https://myaccount.google.com/apppasswords (requires 2FA on the account)
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM_NAME=

# --- Inngest ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- App ---
APP_URL=http://localhost:3000

# --- YouTube gated-email reveal (headless Chromium + CapSolver) ---
# When both CAPSOLVER_API_KEY and YT_GOOGLE_COOKIE are set, the email
# enrichment pipeline tries to reveal the gated "View email address" on a
# channel's About page. Requires a runtime that can run Chromium
# (local/worker) or a remote browser via BROWSER_WS_ENDPOINT.
CAPSOLVER_API_KEY=
# Cookie header copied from a logged-in youtube.com session (use a burner Google account)
YT_GOOGLE_COOKIE=
# Optional residential proxy for the reveal browser, e.g. http://user:pass@host:port
# (local launch only; for a remote browser configure the proxy on the provider)
YT_REVEAL_PROXY=

# --- YouTube cookie AUTO-REFRESH (optional) ---
# When YT_GOOGLE_COOKIE goes stale, the pipeline can log back into Google with
# these credentials and mint a fresh cookie automatically (saved to settings).
# ⚠️ Scripting Google login is fragile: use a DEDICATED account whose only 2FA
# is an authenticator app (so the TOTP secret below can answer it), and route
# the browser through YT_REVEAL_PROXY matching where you first logged in.
# Leave these blank to disable auto-refresh (you'll paste cookies in by hand).
YT_GOOGLE_EMAIL=
YT_GOOGLE_PASSWORD=
# Base32 authenticator secret (the key behind the QR code). Required only if the
# account has app-based 2-Step Verification.
YT_GOOGLE_TOTP_SECRET=
# Remote/hosted Chromium over CDP — run the reveal OFF your local machine.
# When set, the reveal connects here instead of launching a local browser.
# Free options:
#   • self-hosted browserless:  ws://YOUR_HOST:3000?token=YOUR_TOKEN
#   • Browserbase (free tier):  wss://connect.browserbase.com?apiKey=...&projectId=...
BROWSER_WS_ENDPOINT=